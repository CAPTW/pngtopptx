# slide-image-dual-render hardlock Codex config example
# Exact syntax may need adjustment for your Codex version/environment.
# Review and merge into .codex/config.toml, then restart Codex.

[hooks]
enabled = true

[[hooks.PreToolUse]]
command = "python .codex/hooks/slide_pre_tool_use_policy.py"

[[hooks.PostToolUse]]
command = "python .codex/hooks/slide_post_tool_use_review.py"

[agents]
max_threads = 4
max_depth = 1

# Recommended strict production environment.
# If your Codex version supports env vars in config, set:
# SLIDE_PIPELINE_STRICT=1
#
# If env vars are not supported by this config format, set it in the shell before conversion:
# PowerShell:
#   $env:SLIDE_PIPELINE_STRICT="1"
# Bash:
#   export SLIDE_PIPELINE_STRICT=1
#
# Production conversions should run through slide_pipeline.js, not direct build.js.

# Permission profile example for conversion work.
# Goal: renderer/source config read-only, conversion artifacts writable.
# Adjust to your Codex permission schema.
[permission_profiles.slide_image_dual_render_conversion]
read_only = [
  "scripts/build.js",
  "scripts/lib/atoms_pptx.js",
  "scripts/lib/atoms_html.js",
  "scripts/lib/kit.js",
  "scripts/lib/profile.js",
  "styles/*.json"
]
writable = [
  "work/**",
  "assets/**",
  "out/**",
  "lib/slides.js"
]

# Use a separate profile or set SLIDE_SKILL_DEV=1 only when explicitly developing the Skill itself.
