# slide-image-dual-render hardlock rules
# Hooks and validators are the main enforcement layer. These examples catch simple cases earlier.

forbid /python-pptx/i because "Use backend-agnostic lib/slides.js and slide_pipeline.js, not python-pptx."
forbid /html[-_ ]?to[-_ ]?pptx/i because "HTML-to-PPTX conversion bypasses the approved renderer."
forbid /soffice.*--convert-to\s+pptx/i because "LibreOffice may be used for QA exports, not PPTX creation."
forbid /src\/slide\d+\.(png|jpg|jpeg).*\.pptx/i because "Full-slide raster PPTX shortcuts are invalid."

# Allow QA rasterization/export commands such as PPTX -> PDF -> PNG for inspection.
# Final delivery still requires node scripts/final_gate.js.
